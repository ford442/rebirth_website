---
// BaseLayout.astro — shared shell for every page
export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Community archive for the ReBirth RB-338 software synthesizer — songs, mods, and history preserved.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <title>{title} — ReBirth RB-338 Archive</title>

    <!-- Global styles are imported via the component's style tag below -->
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/rebirth-theme.css`} />
  </head>
  <body class="rebirth-theme">
    <!-- Accessibility skip link -->
    <a href="#main-content" class="skip-nav">Skip to main content</a>

    <!-- Site header -->
    <header class="site-header rb-header">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}`} class="site-logo rb-logo" aria-label="ReBirth RB-338 Archive home">
          <span class="logo-rb">RB</span><span class="logo-338">-338</span>
          <span class="logo-sub">ARCHIVE</span>
        </a>
        <nav class="rb-nav" aria-label="Primary navigation">
          <ul role="list">
            <li><a href={`${import.meta.env.BASE_URL}`} class="rb-nav-btn">Home</a></li>
            <li><a href={`${import.meta.env.BASE_URL}archive/songs`} class="rb-nav-btn">Songs</a></li>
            <li><a href={`${import.meta.env.BASE_URL}archive/mods`} class="rb-nav-btn">Mods</a></li>
            <li><a href={`${import.meta.env.BASE_URL}docs`} class="rb-nav-btn">Docs</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Page content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Site footer -->
    <footer class="site-footer">
      <div class="container">
        <p>
          ReBirth RB-338 Archive &mdash; Community-maintained. Not affiliated with Propellerhead Software.
        </p>
        <p class="footer-build">
          Built with <a href="https://astro.build" rel="noopener noreferrer" target="_blank">Astro</a> &mdash;
          <a href="https://github.com/ford442/rebirth_website" rel="noopener noreferrer" target="_blank">Contribute on GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* ── Header — positional wrapper (visual via .rb-header) ──── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .rb-nav ul {
    display: flex;
    list-style: none;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
  }

  /* ── Footer ─────────────────────────────────────────────────── */
  .site-footer {
    border-top: 2px solid #111;
    padding-block: var(--space-lg);
    margin-top: var(--space-xl);
    background: linear-gradient(0deg, #111 0%, #1a1a1a 100%);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .site-footer .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: center;
    text-align: center;
  }

  .site-footer a {
    color: #666;
    text-decoration: none;
  }

  .site-footer a:hover {
    color: var(--rb-amber, #ffb000);
  }

  .footer-build { opacity: 0.5; }
</style>
