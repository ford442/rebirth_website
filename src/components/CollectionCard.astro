---
// CollectionCard.astro — reusable card for displaying collection sections
export interface Props {
  /** Section object with name and folders */
  section: {
    name: string;
    folders: Array<{
      name: string;
      path: string;
    }>;
  };
  /** Base URL for the archive */
  archiveUrl: string;
}

const { section, archiveUrl } = Astro.props;
---

<div class="collection-section">
  <div class="section-header">{section.name}</div>
  <div class="folder-list">
    {section.folders.map(folder => (
      <a href={`${archiveUrl}/${folder.path}`} target="_blank" class="folder-item">
        <span class="folder-icon">📁</span>
        <span class="folder-name">{folder.name}</span>
        <span class="external-link">↗</span>
      </a>
    ))}
  </div>
</div>

<style>
  .collection-section {
    background: linear-gradient(180deg, #2e2e2e 0%, #252525 100%);
    padding: 0;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #3a3a3a;
    border-top: 2px solid #555;
    box-shadow: 0 4px 16px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.04);
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }

  .collection-section:hover {
    border-color: #ffb000;
    box-shadow: 0 0 16px rgba(0,0,0,0.5), 0 0 10px rgba(255,176,0,0.15);
  }

  .section-header {
    background: linear-gradient(180deg, #333 0%, #2a2a2a 100%);
    border-bottom: 1px solid #111;
    color: #c0c0c0;
    padding: 0.6em 1em;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  .section-header::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ffb000;
    box-shadow: 0 0 6px rgba(255,176,0,0.5);
    flex-shrink: 0;
  }

  .folder-list {
    display: flex;
    flex-direction: column;
  }

  .folder-item {
    padding: 0.55rem 1rem;
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    transition: background-color 120ms ease;
    text-decoration: none;
    color: #888;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .folder-item:last-child {
    border-bottom: none;
  }

  .folder-item:hover {
    background-color: rgba(255, 176, 0, 0.06);
    color: #ffb000;
  }

  .folder-item a {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
  }

  .folder-icon {
    font-size: 0.9em;
    opacity: 0.6;
  }

  .folder-name {
    flex: 1;
  }

  .external-link {
    color: #555;
    font-size: 0.85em;
    transition: color 120ms ease;
  }

  .folder-item:hover .external-link {
    color: #ffb000;
  }
</style>