---
// RBS Song Archive Browser
import BaseLayout from '../layouts/BaseLayout.astro';
import CollectionCard from '../components/CollectionCard.astro';

const archiveBaseUrl = "http://test.1ink.us/rb338/archive/rbs-songs";

interface Collection {
  name: string;
  path: string;
  type: "folder" | "file";
  modified?: string;
  count?: number;
}

const collections = {
  featured: {
    name: "Featured Collections",
    folders: [
      { name: "Contests", path: "Featured_Collections/Contests" },
      { name: "MODs", path: "Featured_Collections/MODs" }
    ]
  },
  bySource: {
    name: "By Source",
    folders: [
      { name: "Rebirth 1.5", path: "By_Source/Rebirth_1.5" },
      { name: "Rebirth 2.0", path: "By_Source/Rebirth_2.0" },
      { name: "Archives", path: "By_Source/Archives" }
    ]
  },
  artists: {
    name: "Artists",
    folders: [
      { name: "Cavey", path: "Artists/Cavey" },
      { name: "DJ Caspa", path: "Artists/DJ Caspa" },
      { name: "DJ Knightmare", path: "Artists/DJ Knightmare" },
      { name: "Fanatic", path: "Artists/Fanatic" },
      { name: "Noah Cohn", path: "Artists/Noah Cohn" },
      { name: "Noah Cohn Complete", path: "Artists/Noah_Cohn_Complete" },
      { name: "Noah Cohn Extended", path: "Artists/Noah_Cohn_Extended" },
      { name: "Rotorkopf", path: "Artists/Rotorkopf" }
    ]
  },
  monthly: {
    name: "Monthly Archive",
    folders: [
      { name: "January to December", path: "Monthly_Archive" }
    ]
  },
  other: {
    name: "Other Collections",
    folders: [
      { name: "Color X", path: "Other_Collections/Color X" },
      { name: "Euro Pack", path: "Other_Collections/Euro Pack" },
      { name: "Freestyle Pack", path: "Other_Collections/Freestyle Pack" },
      { name: "Rotorkopf 2", path: "Other_Collections/Rotorkopf 2" },
      { name: "Saturday Morning", path: "Other_Collections/Saturday Morning" }
    ]
  }
};
---

<BaseLayout title="RBS Song Archive" description="Browse and explore ReBirth RB-338 song collections, artists, and sources.">

  <div class="archive-page">
    <div class="container">

      <!-- Page header module -->
      <div class="archive-header rb-module">
        <div class="rb-module__header">
          <span class="rb-module__title">RBS SONG ARCHIVE BROWSER</span>
          <span class="rb-led rb-led--online"><span class="rb-led__dot"></span>2000+ FILES</span>
        </div>
        <div class="rb-module__body archive-header-body">
          <p class="archive-subtitle">Browse and explore Rebirth songs from various collections, artists, and sources</p>
          <div class="search-bar">
            <input
              type="text"
              id="searchInput"
              placeholder="Search collections and artists..."
              class="rb-search-input"
              aria-label="Search collections"
            />
            <button onclick="clearSearch()" class="rb-mix-btn search-clear-btn" type="button">Clear</button>
          </div>
        </div>
      </div>

      <!-- LCD stats bar -->
      <div class="archive-stats">
        <div class="rb-lcd" aria-label="Main collections">
          <div class="lcd-label">COLLECTIONS</div>
          <div class="lcd-value">5</div>
        </div>
        <div class="rb-lcd" aria-label="Featured artists">
          <div class="lcd-label">ARTISTS</div>
          <div class="lcd-value">8</div>
        </div>
        <div class="rb-lcd" aria-label="Total songs">
          <div class="lcd-label">SONGS</div>
          <div class="lcd-value">2000<span class="lcd-unit">+</span></div>
        </div>
        <div class="rb-lcd" aria-label="Monthly archives">
          <div class="lcd-label">ARCHIVES</div>
          <div class="lcd-value">12</div>
        </div>
      </div>

      <!-- View toggle -->
      <div class="view-toggle" role="group" aria-label="View mode">
        <button class="rb-pattern-btn view-btn active" id="btnGrid" onclick="switchView('grid')" type="button">Grid View</button>
        <button class="rb-mix-btn view-btn"    id="btnList" onclick="switchView('list')" type="button">List View</button>
      </div>

      <!-- Grid view -->
      <div id="gridView" class="collections-grid" role="main">
        {collections.featured && (
          <CollectionCard section={collections.featured} archiveUrl={archiveBaseUrl} />
        )}
        {collections.bySource && (
          <CollectionCard section={collections.bySource} archiveUrl={archiveBaseUrl} />
        )}
        {collections.artists && (
          <CollectionCard section={collections.artists} archiveUrl={archiveBaseUrl} />
        )}
        {collections.monthly && (
          <CollectionCard section={collections.monthly} archiveUrl={archiveBaseUrl} />
        )}
        {collections.other && (
          <CollectionCard section={collections.other} archiveUrl={archiveBaseUrl} />
        )}
      </div>

      <!-- List view -->
      <div id="listView" style="display:none" role="main">
        <div class="rb-module list-table-wrapper">
          <div class="rb-module__header">
            <span class="rb-module__title">ALL COLLECTIONS</span>
          </div>
          <div class="rb-module__body" style="padding:0">
            <table class="archive-table">
              <thead>
                <tr>
                  <th>Collection</th>
                  <th>Path</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="listTableBody"></tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  .archive-page {
    padding-block: 2rem 4rem;
    background: #0f0f0f;
    min-height: 60vh;
  }

  /* Header module */
  .archive-header { margin-bottom: 1rem; }

  .archive-header-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .archive-subtitle {
    font-size: 0.875rem;
    color: #888;
    margin: 0;
  }

  /* Search bar */
  .search-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .rb-search-input {
    flex: 1;
    min-width: 200px;
    padding: 0.5em 0.8em;
    background: #111;
    border: 1px solid #3a3a3a;
    border-radius: 3px;
    color: #c0c0c0;
    font-family: 'Courier New', monospace;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 120ms ease;
  }

  .rb-search-input:focus {
    border-color: #ffb000;
    box-shadow: 0 0 0 2px rgba(255,176,0,0.15);
  }

  .rb-search-input::placeholder { color: #555; }

  .search-clear-btn { align-self: flex-start; }

  /* Stats row */
  .archive-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .lcd-unit {
    font-size: 0.6em;
    color: #b37800;
    margin-left: 1px;
  }

  /* View toggle */
  .view-toggle {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .view-btn {
    opacity: 0.6;
    transition: opacity 120ms ease;
  }

  .view-btn.active { opacity: 1; }

  /* Collections grid */
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* List table */
  .archive-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Courier New', monospace;
    font-size: 0.82rem;
  }

  .archive-table th {
    text-align: left;
    padding: 0.6em 1em;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    border-bottom: 1px solid #2a2a2a;
    background: #1e1e1e;
  }

  .archive-table td {
    padding: 0.55em 1em;
    border-bottom: 1px solid #1e1e1e;
    color: #888;
    vertical-align: middle;
  }

  .archive-table tr:hover td {
    background: rgba(255,176,0,0.04);
    color: #c0c0c0;
  }

  .archive-table td:first-child { color: #c0c0c0; }

  .archive-table .open-link {
    color: #ffb000;
    text-decoration: none;
    transition: color 120ms ease;
  }

  .archive-table .open-link:hover {
    color: #3dba66;
  }
</style>

<script>
  const archiveBaseUrl = "http://test.1ink.us/rb338/archive/rbs-songs";

  const allCollections = {
    featured: {
      name: "Featured Collections",
      folders: [
        { name: "Contests", path: "Featured_Collections/Contests" },
        { name: "MODs", path: "Featured_Collections/MODs" }
      ]
    },
    bySource: {
      name: "By Source",
      folders: [
        { name: "Rebirth 1.5", path: "By_Source/Rebirth_1.5" },
        { name: "Rebirth 2.0", path: "By_Source/Rebirth_2.0" },
        { name: "Archives", path: "By_Source/Archives" }
      ]
    },
    artists: {
      name: "Artists",
      folders: [
        { name: "Cavey", path: "Artists/Cavey" },
        { name: "DJ Caspa", path: "Artists/DJ Caspa" },
        { name: "DJ Knightmare", path: "Artists/DJ Knightmare" },
        { name: "Fanatic", path: "Artists/Fanatic" },
        { name: "Noah Cohn", path: "Artists/Noah Cohn" },
        { name: "Noah Cohn Complete", path: "Artists/Noah_Cohn_Complete" },
        { name: "Noah Cohn Extended", path: "Artists/Noah_Cohn_Extended" },
        { name: "Rotorkopf", path: "Artists/Rotorkopf" }
      ]
    },
    monthly: {
      name: "Monthly Archive",
      folders: [
        { name: "January to December", path: "Monthly_Archive" }
      ]
    },
    other: {
      name: "Other Collections",
      folders: [
        { name: "Color X", path: "Other_Collections/Color X" },
        { name: "Euro Pack", path: "Other_Collections/Euro Pack" },
        { name: "Freestyle Pack", path: "Other_Collections/Freestyle Pack" },
        { name: "Rotorkopf 2", path: "Other_Collections/Rotorkopf 2" },
        { name: "Saturday Morning", path: "Other_Collections/Saturday Morning" }
      ]
    }
  };

  // Search functionality
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      const sections = document.querySelectorAll('.collection-section');

      sections.forEach(section => {
        const sectionTitle = section.querySelector('.section-header')?.textContent?.toLowerCase() ?? '';
        const folderItems = section.querySelectorAll('.folder-item');
        let hasVisibleItems = false;

        folderItems.forEach(item => {
          const folderName = item.querySelector('.folder-name')?.textContent?.toLowerCase() ?? '';
          const matches = sectionTitle.includes(query) || folderName.includes(query) || query === '';
          (item as HTMLElement).style.display = matches ? '' : 'none';
          if (matches) hasVisibleItems = true;
        });

        (section as HTMLElement).style.display = hasVisibleItems || query === '' ? '' : 'none';
      });
    });
  }

  function clearSearch() {
    const inp = document.getElementById('searchInput') as HTMLInputElement | null;
    if (inp) {
      inp.value = '';
      inp.dispatchEvent(new Event('input'));
    }
  }

  function switchView(view: string) {
    const gridView = document.getElementById('gridView');
    const listView = document.getElementById('listView');
    const btnGrid  = document.getElementById('btnGrid');
    const btnList  = document.getElementById('btnList');

    if (!gridView || !listView) return;

    if (view === 'grid') {
      gridView.style.display = 'grid';
      listView.style.display = 'none';
      btnGrid?.classList.add('active');
      btnList?.classList.remove('active');
    } else {
      gridView.style.display = 'none';
      listView.style.display = 'block';
      btnList?.classList.add('active');
      btnGrid?.classList.remove('active');
      renderListView();
    }
  }

  function renderListView() {
    const tbody = document.getElementById('listTableBody');
    if (!tbody) return;
    tbody.innerHTML = '';

    Object.values(allCollections).forEach(section => {
      section.folders.forEach(folder => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${folder.name}</td>
          <td style="color:#555">${folder.path}</td>
          <td><a href="${archiveBaseUrl}/${folder.path}" target="_blank" class="open-link" rel="noopener noreferrer">Open ↗</a></td>
        `;
        tbody.appendChild(row);
      });
    });
  }
</script>
</html>